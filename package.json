    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "dotenv": "^17.2.4",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jose": "^6.1.3",
    "lucide-react": "^0.564.0",
    "mysql2": "^3.16.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "vercel": "^50.18.2",
    "xlsx": "^0.18.5"
  },
