{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-inquiry-latest",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/sync-batch",
      "schedule": "5 */2 * * *"
    },
    {
      "path": "/api/cron/sync-consultancy",
      "schedule": "8 */2 * * *"
    },
    {
      "path": "/api/cron/sync-all",
      "schedule": "10 */2 * * *"
    },
    {
      "path": "/api/cron/sync-alumni-jobs",
      "schedule": "20 */6 * * *"
    }
  ]
}
