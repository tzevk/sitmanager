{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/meta-leads-refresh",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/db-connection-cleanup",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/suvidya-inquiry-sync",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/suvidya-inquiry-sync-pune",
      "schedule": "1-59/2 * * * *"
    },
    {
      "path": "/api/cron/meta-batch-recommendations",
      "schedule": "5 0 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 300
    }
  }
}
